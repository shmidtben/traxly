{
  "name": "traxly",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "pnpm --filter @traxly/db run generate",
    "db:push": "pnpm --filter @traxly/db run push",
    "db:studio": "pnpm --filter @traxly/db run studio",
    "db:seed": "pnpm --filter @traxly/db run seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
